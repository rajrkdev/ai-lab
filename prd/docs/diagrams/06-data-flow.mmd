%% InsureChat v3.0 — Data Flow Diagram (DFD Level 1)
%% Shows how data flows between processes, external entities, and data stores

graph TB
    subgraph External["External Entities"]
        USER["👤 User<br/>(Customer / Developer)"]
        ADMIN["👤 Admin<br/>(Document Uploader)"]
        CLAUDE_API["☁️ Claude API"]
        GEMINI_API["☁️ Gemini API"]
    end

    subgraph Processes["Processes"]
        P1["P1: Input Validation<br/>──────────────<br/>• Check length ≤ 500<br/>• Scan 12 injection patterns<br/>• Redact PII via Presidio"]
        P2["P2: Query Embedding<br/>──────────────<br/>• Gemini gemini-embedding-001<br/>• 768-dim vector<br/>• task: RETRIEVAL_QUERY"]
        P3["P3: Vector Retrieval<br/>──────────────<br/>• Cosine similarity search<br/>• Top-5 chunks<br/>• Score threshold: 0.60"]
        P4["P4: LLM Generation<br/>──────────────<br/>• Claude Sonnet primary<br/>• Gemini Flash fallback<br/>• RAG prompt construction"]
        P5["P5: Output Validation<br/>──────────────<br/>• PII masking (Presidio)<br/>• Hallucination detection<br/>• Confidence gating"]
        P6["P6: Intent Classification<br/>──────────────<br/>• Claude Haiku<br/>• 9 microsite intents<br/>• 8 support intents"]
        P7["P7: Document Ingestion<br/>──────────────<br/>• Extract (PDF/DOCX/TXT...)<br/>• Chunk (512 tok, 64 overlap)<br/>• Embed → Store"]
        P8["P8: Analytics & Reporting<br/>──────────────<br/>• KPI aggregation<br/>• Z-score anomaly detection<br/>• PDF/Excel reports"]
    end

    subgraph DataStores["Data Stores"]
        D1[("D1: ChromaDB<br/>──────────────<br/>insurance_docs collection<br/>support_docs collection<br/>768-dim cosine index")]
        D2[("D2: SQLite<br/>──────────────<br/>sessions table<br/>messages table<br/>feedback table")]
        D3[("D3: JSONL Audit Log<br/>──────────────<br/>Append-only security log<br/>All interactions")]
        D4[("D4: config.yaml<br/>──────────────<br/>LLM, security, RAG,<br/>embeddings, analytics")]
    end

    %% User chat flow
    USER -->|"query + session_id"| P1
    P1 -->|"sanitized_query + pii_list"| P2
    P2 -->|"768-dim vector"| P3
    P3 -->|"chunks + sources + scores"| P4
    P4 -->|"raw LLM response"| P5
    P5 -->|"validated response"| USER
    P1 -->|"query text"| P6
    P6 -->|"intent category"| D2

    %% LLM API calls
    P4 -->|"system_prompt + rag_prompt"| CLAUDE_API
    CLAUDE_API -->|"response + tokens"| P4
    P4 -.->|"fallback prompt"| GEMINI_API
    GEMINI_API -.->|"fallback response"| P4
    P2 -->|"embed_content()"| GEMINI_API
    GEMINI_API -->|"768-dim embedding"| P2
    P6 -->|"classify prompt"| CLAUDE_API

    %% Data store interactions
    P3 <-->|"query / results"| D1
    P7 -->|"chunks + embeddings"| D1
    P1 -->|"log blocked"| D2
    P5 -->|"log interaction"| D2
    P5 -->|"audit entry"| D3
    P8 <-->|"read metrics"| D2
    P1 -.->|"read config"| D4
    P4 -.->|"read config"| D4
    P5 -.->|"read config"| D4

    %% Admin ingestion flow
    ADMIN -->|"file + chatbot_type"| P7
    P7 -->|"ingestion result"| ADMIN
    P7 -->|"embed_documents()"| GEMINI_API

    %% Analytics
    USER -.->|"request analytics"| P8
    P8 -.->|"KPIs / reports / anomalies"| USER

    classDef process fill:#2196F3,stroke:#1565C0,color:#fff
    classDef store fill:#607D8B,stroke:#37474F,color:#fff
    classDef external fill:#4CAF50,stroke:#2E7D32,color:#fff

    class P1,P2,P3,P4,P5,P6,P7,P8 process
    class D1,D2,D3,D4 store
    class USER,ADMIN,CLAUDE_API,GEMINI_API external
