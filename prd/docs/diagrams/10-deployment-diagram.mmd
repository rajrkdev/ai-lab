%% InsureChat v3.0 — Deployment Diagram
%% Shows services, ports, processes, and infrastructure

graph TB
    subgraph Machine["🖥️ Local Machine / Server"]
        direction TB
        
        subgraph PythonVenv["🐍 Python Virtual Environment<br/>C:\\Users\\...\\Documents\\.venv"]
            direction TB
            
            subgraph Process1["Process 1: FastAPI (uvicorn)"]
                FA["⚙️ FastAPI Server<br/>uvicorn web.fastapi_server:app<br/>──────────────<br/>Host: 0.0.0.0<br/>Port: 8000<br/>──────────────<br/>11 REST endpoints<br/>Rate limiting (slowapi)<br/>CORS middleware"]
            end
            
            subgraph Process2["Process 2: Streamlit Microsite"]
                SM2["🖥️ Streamlit App<br/>streamlit run web/streamlit_microsite.py<br/>──────────────<br/>Host: localhost<br/>Port: 8501<br/>──────────────<br/>Insurance Customer Chatbot"]
            end
            
            subgraph Process3["Process 3: Streamlit Support"]
                SS2["🖥️ Streamlit App<br/>streamlit run web/streamlit_support.py<br/>──────────────<br/>Host: localhost<br/>Port: 8502<br/>──────────────<br/>Developer Support Chatbot"]
            end
            
            subgraph Process4["Process 4: MCP Server (optional)"]
                MCP2["🔧 FastMCP Server<br/>python -m mcp_server.server<br/>──────────────<br/>MCP Protocol<br/>10 registered tools"]
            end
        end
        
        subgraph FileSystem["📁 File System"]
            direction LR
            
            subgraph DataDir["./data/"]
                CHROMA2["chroma_db/<br/>ChromaDB persistent store<br/>• chroma.sqlite3<br/>• HNSW indexes"]
                SQLITE2["analytics.db<br/>SQLite database"]
                AUDIT["audit_log.jsonl<br/>Security audit trail"]
            end
            
            subgraph DataDocs["./data/insurance/<br/>./data/support/"]
                DOCS["Source documents<br/>(PDF, DOCX, TXT, etc.)"]
            end
            
            CONFIGF["config.yaml<br/>System configuration"]
            ENVF[".env<br/>API keys"]
        end
    end
    
    subgraph ExternalServices["☁️ External Cloud Services"]
        direction LR
        
        subgraph Anthropic["Anthropic API"]
            A1["claude-sonnet-4-6<br/>(Answer generation)"]
            A2["claude-haiku-4-5-20251001<br/>(Intent classification)"]
        end
        
        subgraph Google["Google AI API"]
            G1["gemini-2.0-flash<br/>(LLM fallback)"]
            G2["gemini-embedding-001<br/>(Text embeddings, 768-dim)"]
        end
    end
    
    subgraph LaunchScript["🚀 run.ps1 Launch Script"]
        LS["Starts all 3 processes:<br/>1. uvicorn (port 8000)<br/>2. streamlit microsite (8501)<br/>3. streamlit support (8502)"]
    end
    
    %% Connections
    SM2 -->|"HTTP :8000"| FA
    SS2 -->|"HTTP :8000"| FA
    
    FA --> CHROMA2
    FA --> SQLITE2
    FA --> AUDIT
    FA --> CONFIGF
    FA --> ENVF
    
    FA -->|"HTTPS"| A1
    FA -->|"HTTPS"| A2
    FA -->|"HTTPS"| G1
    FA -->|"HTTPS"| G2
    
    MCP2 --> FA
    
    LS --> FA
    LS --> SM2
    LS --> SS2

    classDef process fill:#2196F3,stroke:#1565C0,color:#fff
    classDef file fill:#607D8B,stroke:#37474F,color:#fff
    classDef cloud fill:#9C27B0,stroke:#6A1B9A,color:#fff
    classDef script fill:#4CAF50,stroke:#2E7D32,color:#fff

    class FA,SM2,SS2,MCP2 process
    class CHROMA2,SQLITE2,AUDIT,DOCS,CONFIGF,ENVF file
    class A1,A2,G1,G2 cloud
    class LS script
