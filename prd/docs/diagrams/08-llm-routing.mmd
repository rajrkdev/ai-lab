%% InsureChat v3.0 — LLM Routing & Fallback Chain
%% Shows model selection, primary/fallback logic, and all LLM touchpoints

graph TB
    subgraph Config["⚙️ Configuration (config.yaml)"]
        CFG["llm_routing:<br/>  primary: claude-sonnet-4-6<br/>  fallback: gemini-2.0-flash<br/>  classifier: claude-haiku-4-5-20251001<br/>  mode: auto<br/>  max_tokens: 1024<br/>  temperature: 0.2"]
    end

    subgraph Pipeline["🔄 LLM Touchpoints in Pipeline"]
        direction TB
        TP1["1️⃣ Intent Classification<br/>(Pre-pipeline, best-effort)"]
        TP2["2️⃣ RAG Answer Generation<br/>(Core pipeline step)"]
    end

    subgraph Classification["🏷️ Intent Classification"]
        direction TB
        CQ["User Query + Chatbot Type"]
        CP["Classification Prompt:<br/>'Classify into ONE category...'"]
        CH["Claude Haiku<br/>claude-haiku-4-5-20251001<br/>temp=0.0, max_tokens=50"]
        CV{"Response in<br/>VALID_INTENTS?"}
        CI_OK["Return intent<br/>(e.g. 'policy_coverage')"]
        CI_OTHER["Return 'other'"]
        CI_ERR["Return 'other'<br/>(graceful failure)"]
    end

    subgraph Generation["🤖 Answer Generation"]
        direction TB
        
        RP["build_rag_prompt()<br/>Chunks + Sources + Query"]
        SP["System Prompt<br/>(per chatbot type)"]
        HIST["Conversation History<br/>Last N turns (max 5)<br/>Token-budget trimmed (max 4000)"]
        
        subgraph Primary["Primary: Claude Sonnet"]
            CLAUDE["☁️ Anthropic API<br/>claude-sonnet-4-6<br/>max_tokens=1024<br/>temperature=0.2<br/>messages: history + rag_prompt"]
        end
        
        subgraph Fallback["Fallback: Gemini Flash"]
            GEMINI["☁️ Google Gemini API<br/>gemini-2.0-flash<br/>max_tokens=1024<br/>temperature=0.2"]
        end
        
        subgraph LastResort["Last Resort: Static Message"]
            STATIC["'Our AI service is<br/>temporarily unavailable.<br/>Please try again.'"]
        end

        RESULT["Return:<br/>{ response, tokens_used, model }"]
    end

    subgraph Prompts["📋 System Prompts"]
        direction TB
        PM["Microsite Prompt:<br/>• Insurance assistant persona<br/>• Answer ONLY from context<br/>• No made-up policy details<br/>• Cite source documents<br/>• Empathy for distressed customers<br/>• No competitor discussion<br/>• No legal/financial advice<br/>• Use history for follow-ups"]
        PS["Support Prompt:<br/>• Technical assistant persona<br/>• Answer ONLY from docs<br/>• Include error codes<br/>• Actionable fix suggestions<br/>• Developer-friendly tone<br/>• No pricing/contract discussion<br/>• Use history for follow-ups"]
    end

    CQ --> CP
    CP --> CH
    CH --> CV
    CV -->|Yes| CI_OK
    CV -->|No| CI_OTHER
    CH -.->|API Error| CI_ERR

    RP --> CLAUDE
    SP --> CLAUDE
    HIST --> CLAUDE
    HIST -.-> GEMINI
    CLAUDE -->|Success| RESULT
    CLAUDE -->|APIError| GEMINI
    GEMINI -->|Success| RESULT
    GEMINI -->|Exception| STATIC
    STATIC --> RESULT

    CFG -.->|"primary model"| CLAUDE
    CFG -.->|"fallback model"| GEMINI
    CFG -.->|"classifier model"| CH

    classDef primary fill:#2196F3,stroke:#1565C0,color:#fff
    classDef fallback fill:#FF9800,stroke:#E65100,color:#fff
    classDef error fill:#F44336,stroke:#B71C1C,color:#fff
    classDef config fill:#9C27B0,stroke:#6A1B9A,color:#fff
    classDef success fill:#4CAF50,stroke:#2E7D32,color:#fff

    class CLAUDE primary
    class GEMINI fallback
    class STATIC error
    class CFG config
    class CI_OK,RESULT success
