# ──────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY  (Required)
# API key for Anthropic's Claude models.
# Used as the PRIMARY LLM for:
#   - RAG answer generation (claude-sonnet-4-6)
#   - Query intent classification (claude-haiku-4-5)
# If Claude is unreachable, the system falls back to Gemini.
# Get your key at: https://console.anthropic.com/
# ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ──────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY  (Required)
# API key for Google's Gemini models.
# Used for:
#   - FALLBACK LLM when Claude is unavailable (gemini-2.0-flash)
#   - PRIMARY text embeddings for RAG vector search (gemini-embedding-001)
#   - Embedding fallback when Voyage AI is unavailable
# Also accepted as GOOGLE_API_KEY (checked as fallback).
# Get your key at: https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────────────────────────────
# ADMIN_API_KEY  (Placeholder — not yet enforced)
# Intended for authenticating privileged admin endpoints:
#   /ingest, /analytics, /analytics/sessions, /reports, /analytics/anomalies
# Currently defined for future security implementation; endpoints are
# accessible without this key for now.
# ──────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=your_admin_key_here
