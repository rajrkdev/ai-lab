---
/**
 * Custom Sidebar — renders sidebar-topics navigation with the same inline SVG
 * icons used on the homepage cards, then delegates to Starlight's default
 * Sidebar for the per-page content panel.
 */
import Default from '@astrojs/starlight/components/Sidebar.astro';

const { hasSidebar } = Astro.locals.starlightRoute;
const { topics, isPageWithTopic } = Astro.locals.starlightSidebarTopics;

/**
 * Map each topic icon key (as set in astro.config.mjs) to the SVG *inner
 * content* of the matching homepage card icon. These are stroke-based Lucide
 * icons that mirror the cards on index.mdx exactly.
 */
const ICON_SVG: Record<string, string> = {
  // RAG Guides — database cylinder
  rocket: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>`,

  // BERT Architectures — CPU / processor chip
  binoculars: `<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/>`,

  // LangChain Reference — chain / link
  puzzle: `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`,

  // Claude Code — terminal  >_
  setting: `<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>`,

  // Cert Prep — medal / award badge
  star: `<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>`,
};
---

{
  hasSidebar && isPageWithTopic && (
    <ul class="sl-topics">
      {topics.map((topic) => {
        const svgContent = topic.icon ? (ICON_SVG[topic.icon] ?? '') : '';
        return (
          <li>
            <a href={topic.link} class:list={{ 'sl-topics-current': topic.isCurrent }}>
              {svgContent && (
                <span class="sl-topics-icon">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={svgContent}
                  />
                </span>
              )}
              <span>{topic.label}</span>
            </a>
          </li>
        );
      })}
    </ul>
  )
}

<Default>
  <slot />
</Default>

<style>
  .sl-topics {
    list-style: none;
    padding: 0;
  }

  .sl-topics::after {
    content: '';
    display: block;
    margin-top: 1rem;
    height: 1px;
    border-top: 1px solid var(--sl-color-hairline-light);
  }

  .sl-topics li + li {
    margin-top: 0.25rem;
  }

  .sl-topics a {
    align-items: center;
    color: var(--sl-color-white);
    display: flex;
    font-size: var(--sl-text-base);
    font-weight: 600;
    gap: 0.5rem;
    line-height: 1.5;
    padding: 0.3em 0.5rem;
    text-decoration: none;
  }

  .sl-topics a:is(.sl-topics-current, :hover, :focus-visible) {
    color: var(--sl-color-accent-high);
  }

  :global([data-theme='light']) .sl-topics a.sl-topics-current {
    color: var(--sl-color-accent);
  }

  .sl-topics-icon {
    align-items: center;
    border-radius: 0.25rem;
    border: 1px solid var(--sl-color-gray-4);
    display: flex;
    justify-content: center;
    padding: 0.25rem;
  }

  .sl-topics a:is(.sl-topics-current, :hover, :focus-visible) .sl-topics-icon {
    background-color: var(--sl-color-text-accent);
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-text-invert);
  }
</style>
