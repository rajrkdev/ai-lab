---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/PageTitle.astro';

const { entry } = Astro.props;
const level = entry?.data?.level as string | undefined;
---

<Default {...Astro.props}><slot /></Default>

{level && (
  <div class="page-meta">
    {level === 'beginner' && <span class="badge badge-beginner">Beginner</span>}
    {level === 'intermediate' && <span class="badge badge-intermediate">Intermediate</span>}
    {level === 'advanced' && <span class="badge badge-advanced">Advanced</span>}
  </div>
)}

<style>
  .page-meta {
    display: flex;
    gap: 0.5rem;
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
  }

  .badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-family: var(--sl-font-mono);
  }

  .badge-beginner {
    background: #e6f5ef;
    color: #006638;
  }

  .badge-intermediate {
    background: #e8f1fb;
    color: #1a5fa8;
  }

  .badge-advanced {
    background: #faeeda;
    color: #7a4e0a;
  }

  [data-theme='dark'] .badge-beginner {
    background: #003d1f;
    color: #00d46a;
  }

  [data-theme='dark'] .badge-intermediate {
    background: #0c2347;
    color: #58a6ff;
  }

  [data-theme='dark'] .badge-advanced {
    background: #3d2000;
    color: #f5a623;
  }
</style>
