---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/PageTitle.astro';
import { Breadcrumbs } from 'astro-breadcrumbs';

const { entry } = Astro.props;
const level = entry?.data?.level as string | undefined;

const path = Astro.url.pathname;
const moduleLabels: Record<string, string> = {
  rag: 'RAG Guides',
  bert: 'BERT Architectures',
  langchain: 'LangChain Reference',
  'claude-code': 'Claude Code',
  cert: 'Cert Prep',
};
const segments = path.replace(/^\/ai-lab\//, '').split('/').filter(Boolean);
const moduleName = moduleLabels[segments[0]];
const customizeLinks = moduleName ? [{ index: 1, text: moduleName }] : [];
---

<Breadcrumbs
  schemaJsonScript={false}
  linkTextFormat="capitalized"
  excludeCurrentPage={true}
  customizeLinks={customizeLinks}
>
  <!-- Home icon -->
  <svg slot="index" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="Home" role="img">
    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
    <polyline points="9 22 9 12 15 12 15 22"/>
  </svg>
  <!-- Chevron separator -->
  <svg slot="separator" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="9 18 15 12 9 6"/>
  </svg>
</Breadcrumbs>

<Default {...Astro.props}><slot /></Default>

{level && (
  <div class="page-meta">
    {level === 'beginner' && <span class="badge badge-beginner">Beginner</span>}
    {level === 'intermediate' && <span class="badge badge-intermediate">Intermediate</span>}
    {level === 'advanced' && <span class="badge badge-advanced">Advanced</span>}
  </div>
)}

<style>
  .page-meta {
    display: flex;
    gap: 0.5rem;
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
  }

  .badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-family: var(--sl-font-mono);
  }

  .badge-beginner {
    background: #e6f5ef;
    color: #006638;
  }

  .badge-intermediate {
    background: #e8f1fb;
    color: #1a5fa8;
  }

  .badge-advanced {
    background: #faeeda;
    color: #7a4e0a;
  }

  [data-theme='dark'] .badge-beginner {
    background: #003d1f;
    color: #00d46a;
  }

  [data-theme='dark'] .badge-intermediate {
    background: #0c2347;
    color: #58a6ff;
  }

  [data-theme='dark'] .badge-advanced {
    background: #3d2000;
    color: #f5a623;
  }
</style>
