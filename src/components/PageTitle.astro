---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/PageTitle.astro';

const { entry } = Astro.props;
const level = entry?.data?.level as string | undefined;
---

<Default {...Astro.props}><slot /></Default>

{level && (
  <div class="page-meta">
    {level === 'beginner' && <span class="badge badge-beginner">Beginner</span>}
    {level === 'intermediate' && <span class="badge badge-intermediate">Intermediate</span>}
    {level === 'advanced' && <span class="badge badge-advanced">Advanced</span>}
  </div>
)}

<div
  id="reading-progress"
  role="progressbar"
  aria-valuenow="0"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-label="Reading progress"
></div>

<script>
  function initProgressBar() {
    var bar = document.getElementById('reading-progress');
    if (!bar) return;
    function update() {
      var scroll = window.scrollY;
      var height = document.body.scrollHeight - window.innerHeight;
      var pct = height > 0 ? Math.round((scroll / height) * 100) : 0;
      bar.style.width = pct + '%';
      bar.setAttribute('aria-valuenow', String(pct));
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
  document.addEventListener('DOMContentLoaded', initProgressBar);
  document.addEventListener('astro:page-load', initProgressBar);
</script>

<style>
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--sl-color-accent);
    z-index: 9999;
    transition: width 0.1s linear;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #reading-progress {
      transition: none;
    }
  }

  .page-meta {
    display: flex;
    gap: 0.5rem;
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
  }

  .badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-family: var(--sl-font-mono);
  }

  .badge-beginner {
    background: #e6f5ef;
    color: #006638;
  }

  .badge-intermediate {
    background: #e8f1fb;
    color: #1a5fa8;
  }

  .badge-advanced {
    background: #faeeda;
    color: #7a4e0a;
  }

  [data-theme='dark'] .badge-beginner {
    background: #003d1f;
    color: #00d46a;
  }

  [data-theme='dark'] .badge-intermediate {
    background: #0c2347;
    color: #58a6ff;
  }

  [data-theme='dark'] .badge-advanced {
    background: #3d2000;
    color: #f5a623;
  }
</style>
