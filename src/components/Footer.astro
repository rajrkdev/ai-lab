---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Footer.astro';

const path = Astro.url.pathname;
function active(segment: string) {
  return path.startsWith(`/ai-lab/${segment}/`) || path === `/ai-lab/${segment}` ? 'page' : undefined;
}
---

<Default {...Astro.props}><slot /></Default>

<footer class="ctx-site-footer">
  <div class="ctx-footer-inner">
    <span class="ctx-footer-brand">
      <code>Context v2.1</code> &mdash; AI Learning Lab
    </span>
    <nav class="ctx-footer-links" aria-label="Footer navigation">
      <a href="/ai-lab/rag/">RAG</a>
      <a href="/ai-lab/bert/">BERT</a>
      <a href="/ai-lab/langchain/">LangChain</a>
      <a href="/ai-lab/claude-code/">Claude Code</a>
      <a href="/ai-lab/cert/">Cert Prep</a>
    </nav>
  </div>
</footer>

<nav class="ctx-mobile-tab-bar" aria-label="Module navigation">
  <a href="/ai-lab/rag/" class="ctx-tab" aria-label="RAG Guides" aria-current={active('rag')}>
    <!-- Send/rocket icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9 22 2z"/>
    </svg>
    <span>RAG</span>
  </a>
  <a href="/ai-lab/bert/" class="ctx-tab" aria-label="BERT Architectures" aria-current={active('bert')}>
    <!-- CPU/chip icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/>
      <path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/>
    </svg>
    <span>BERT</span>
  </a>
  <a href="/ai-lab/langchain/" class="ctx-tab" aria-label="LangChain Reference" aria-current={active('langchain')}>
    <!-- Link/chain icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
    </svg>
    <span>LangChain</span>
  </a>
  <a href="/ai-lab/claude-code/" class="ctx-tab" aria-label="Claude Code" aria-current={active('claude-code')}>
    <!-- Terminal/prompt icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>
    </svg>
    <span>Code</span>
  </a>
  <a href="/ai-lab/cert/" class="ctx-tab" aria-label="Cert Prep" aria-current={active('cert')}>
    <!-- Award/cert icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
    </svg>
    <span>Cert</span>
  </a>
</nav>

<style>
  .ctx-site-footer {
    border-top: 1px solid var(--sl-color-hairline);
    padding: 1rem 0 0;
    margin-top: 2rem;
  }

  .ctx-footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 12px;
    color: var(--sl-color-gray-3);
  }

  .ctx-footer-brand code {
    color: var(--ctx-green, #00d46a);
    font-size: inherit;
    background: none;
    padding: 0;
    border: none;
  }

  .ctx-footer-links {
    display: flex;
    gap: 1rem;
  }

  .ctx-footer-links a {
    color: inherit;
    text-decoration: none;
  }

  .ctx-footer-links a:hover {
    color: var(--sl-color-text-accent);
  }

  /* ── Mobile tab bar ── */
  .ctx-mobile-tab-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--sl-color-bg-nav);
    border-top: 1px solid var(--sl-color-hairline);
    z-index: 100;
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  @media (max-width: 72rem) {
    .ctx-mobile-tab-bar {
      display: flex;
    }
  }

  .ctx-tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 4px;
    font-size: 10px;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    gap: 3px;
    min-height: 44px;
    transition: color 0.15s;
  }

  .ctx-tab:hover {
    color: var(--sl-color-accent);
    text-decoration: none;
  }

  .ctx-tab[aria-current='page'] {
    color: var(--sl-color-accent);
    font-weight: 600;
  }

  .ctx-tab[aria-current='page'] svg {
    filter: drop-shadow(0 0 4px var(--sl-color-accent));
  }
</style>
